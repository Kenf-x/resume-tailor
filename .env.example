# PostgreSQL (local or hosted)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/resume_tailor?schema=public"

# Single-user MVP: stable id for stored rows
DEFAULT_USER_ID="default-user"

# Local file storage (relative to project root)
UPLOAD_DIR="./uploads"

# OpenAI — required for best parsing, merging, tailoring, and match analysis
OPENAI_API_KEY=""
# Optional model override (defaults to gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"

# If true, app can fall back to basic non-AI heuristics when OpenAI fails/missing.
# Keep this false for high-quality tailored resumes.
ALLOW_HEURISTIC_FALLBACK="false"
